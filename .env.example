# URL to the rbly.js SDK bundle
# For local dev: leave empty or use /sdk/rbly.js (served by Vite middleware from ../conversion-tracking-sdk/dist/)
# For production/CDN: full URL like https://cdn.rebrandly.com/rbly.js
VITE_SDK_URL=/sdk/rbly.js

# Conversion Tracking API base URL
VITE_API_BASE=http://localhost:3000

# Rebrandly API key for SDK initialization
VITE_API_KEY=your_api_key_here
